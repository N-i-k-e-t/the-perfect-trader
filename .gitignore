# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.example
!mobile/.env.example

# Encrypted secrets vault (never commit)
secrets/
secrets/**
!secrets/README.md

# Local Supabase credentials doc (contains service role key)
docs/SUPABASE_PROJECT.local.md
docs/supabase/SUPABASE_PROJECT.local.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# junk / large binaries (not deployed)
$null
legacy/apks/
*.apk

# Flutter (mobile/)
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/build/
mobile/**/build/
mobile/.pub-cache/
mobile/.pub/
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/android/.gradle/
mobile/android/app/debug/
mobile/android/app/profile/
mobile/android/app/release/
mobile/.env

# Flutter mobile (build artifacts only — source in mobile/ is tracked)
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/build/
mobile/**/build/
mobile/.pub-cache/
mobile/.pub/
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/android/.gradle/
mobile/android/app/debug/
mobile/android/app/profile/
mobile/android/app/release/
mobile/.env
