{
  "name": "the-perfect-trader",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "setup:supabase": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-supabase.ps1",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:cloud": "powershell -ExecutionPolicy Bypass -File ./scripts/supabase-cloud.ps1",
    "db:push:url": "powershell -ExecutionPolicy Bypass -File ./scripts/push-db-url.ps1",
    "secrets:init": "powershell -ExecutionPolicy Bypass -File ./scripts/secrets/init-vault.ps1",
    "secrets:unlock": "powershell -ExecutionPolicy Bypass -File ./scripts/secrets/unlock-vault.ps1",
    "secrets:migrate": "powershell -ExecutionPolicy Bypass -File ./scripts/secrets/migrate-env-to-vault.ps1",
    "secrets:sync-mobile": "powershell -ExecutionPolicy Bypass -File ./scripts/secrets/sync-mobile-env.ps1",
    "secrets:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check-secrets.ps1",
    "db:pull": "supabase db pull",
    "db:diff": "supabase db diff -f",
    "db:new": "supabase migration new",
    "db:studio": "supabase studio",
    "db:types": "supabase gen types typescript --local > src/types/database.ts",
    "db:env": "powershell -ExecutionPolicy Bypass -File ./scripts/sync-env-local.ps1",
    "docker:dev": "docker compose --profile dev up dev",
    "docker:build": "docker compose up app --build",
    "deploy:live": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-live.ps1",
    "beta:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/apply-beta-reset.ps1",
    "beta:reset:sql": "powershell -ExecutionPolicy Bypass -File ./scripts/reset-beta-count.ps1",
    "db:tracking": "powershell -ExecutionPolicy Bypass -File ./scripts/open-tracking-migration.ps1",
    "db:tracking:apply": "powershell -ExecutionPolicy Bypass -File ./scripts/apply-user-events.ps1",
    "analytics:verify": "node scripts/check-user-events.mjs && node scripts/verify-vercel-prod-env.mjs",
    "db:staging:link": "powershell -ExecutionPolicy Bypass -File ./scripts/supabase-staging.ps1 -Action link",
    "db:staging:push": "powershell -ExecutionPolicy Bypass -File ./scripts/supabase-staging.ps1 -Action push",
    "db:staging:status": "powershell -ExecutionPolicy Bypass -File ./scripts/supabase-staging.ps1 -Action status",
    "setup:observability": "node scripts/setup-observability.mjs",
    "cron:generate": "node scripts/generate-cron-sql.mjs",
    "tracking:browser": "node scripts/browser-tracking-verify.mjs",
    "report:test": "node scripts/test-weekly-report.mjs",
    "analytics:queries": "node scripts/run-saved-queries-rest.mjs",
    "setup:observability:wait": "powershell -ExecutionPolicy Bypass -File ./scripts/run-setup-observability.ps1",
    "health:check": "node scripts/health-check-all.mjs",
    "auth:test": "node scripts/test-auth-live.mjs",
    "health:signup": "node scripts/smoke-test-signup.mjs",
    "auth:configure": "powershell -ExecutionPolicy Bypass -File ./scripts/configure-supabase-auth.ps1",
    "oauth:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/open-oauth-setup.ps1",
    "oauth:github:fix": "start docs/supabase/GITHUB_OAUTH_FIX.md",
    "oauth:google:fix": "start docs/supabase/GOOGLE_OAUTH_FIX.md",
    "oauth:google": "powershell -ExecutionPolicy Bypass -File ./scripts/open-google-oauth-setup.ps1",
    "oauth:apple": "powershell -ExecutionPolicy Bypass -File ./scripts/open-apple-oauth-setup.ps1",
    "oauth:google:guide": "start docs/supabase/GOOGLE_OAUTH_EASY.md",
    "oauth:enable": "powershell -ExecutionPolicy Bypass -File ./scripts/enable-oauth-providers.ps1",
    "oauth:sync-staging": "node scripts/sync-staging-oauth.mjs",
    "oauth:apply": "powershell -ExecutionPolicy Bypass -File ./scripts/apply-oauth-env.ps1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.1",
    "supabase": "^2.100.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
