# Copy this file to .env.local and fill in real values
# Never commit .env.local to git
# See README.md for setup instructions

## Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_PROJECT_REF=your-project-ref

## AI
GEMINI_API_KEY=your-gemini-api-key-here

## Email (Resend)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM=The Perfect Trader <noreply@yourdomain.com>

## App
NEXT_PUBLIC_APP_URL=https://the-perfect-trader.vercel.app
NEXT_PUBLIC_SITE_URL=https://the-perfect-trader.vercel.app
NEXT_PUBLIC_TWITTER_URL=https://x.com/ThePerfectTrader
NEXT_PUBLIC_BETA_MODE=true
NEXT_PUBLIC_BETA_USER_CAP=10
NEXT_PUBLIC_SUPPORT_EMAIL=support@theperfecttrader.app
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@theperfecttrader.app

## Admin (comma-separated emails with admin access)
ADMIN_EMAILS=your@email.com

## Beta report & contact routing
BETA_REPORT_EMAIL=your@email.com

## Optional — Sentry
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
