# Copy to .env.local — see docs/SUPABASE_PROJECT.local.md (production) or .env.staging.example (staging dev)

# development | staging | production (Vercel sets preview → staging, production → production)
NEXT_PUBLIC_APP_ENV=development

# Prefer STAGING keys for local dev — see docs/supabase/STAGING_PROJECT.md
NEXT_PUBLIC_SUPABASE_URL=https://firqlsjixojnrofycwbs.supabase.co
NEXT_PUBLIC_SITE_URL=https://the-perfect-trader.vercel.app
# Use anon JWT (eyJ...) — see docs/supabase/CONNECT.md
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Optional newer key:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_PROJECT_REF=firqlsjixojnrofycwbs
SUPABASE_REGION=ap-northeast-1

# Secrets (JWTs, DB password, API keys): use encrypted vault — NOT this file.
#   npm run secrets:init
#   npm run secrets:unlock
# See docs/SECURITY_SECRETS.md

# Sentry (optional locally; required on Vercel for error monitoring — docs/observability/SENTRY.md)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Google Gemini (optional — AI journal / terminal)
GEMINI_API_KEY=your-gemini-api-key

# Product (beta: all features free, no trial paywall)
NEXT_PUBLIC_BETA_MODE=true
NEXT_PUBLIC_BETA_USER_CAP=100
NEXT_PUBLIC_SUPPORT_EMAIL=support@theperfecttrader.app
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@theperfecttrader.app
NEXT_PUBLIC_LEGAL_ENTITY=The Perfect Trader
